# Niveau 3c — Multi-stage build
# Stage 1 : build (crée dist/index.js)
FROM node:18-alpine AS builder
WORKDIR /app
COPY package.json index.js ./
RUN npm run build

# Stage 2 : image de production ultra-légère
# Aucun node_modules nécessaire (0 dépendances de prod dans ce projet)
FROM node:18-alpine
WORKDIR /app
COPY --from=builder /app/dist/index.js ./dist/
RUN chown -R node:node /app
USER node
EXPOSE 3000
CMD ["node", "dist/index.js"]
